# Optional runtime settings for the reasoning lab.
#
# The base annotation app works without any API keys.
# AI-assisted labeling requires OPENROUTER_API_KEY.

OPENROUTER_API_KEY=
OPENROUTER_REFERER=
OPENROUTER_APP_NAME=reasoning-lab

# Optional for future provider swaps in the special-capture workflow.
OPENAI_API_KEY=
OPENAI_PROJECT=
OPENAI_ORGANIZATION=

# Optional override. By default the lab uses the bundled snapshot under
# source-data/gpt54/.
REASONING_LAB_BENCHMARK_ROOT=
